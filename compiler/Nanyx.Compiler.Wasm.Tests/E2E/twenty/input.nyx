-- Test 20: Parameterized context instances
-- Tests that [ToString(a) + ToString(b)] works with qualified access ToString(a).f

context ToString(a) = (
  toString: a -> String
)

def compareStrings: [ToString(a) + ToString(b)] (a, b) -> bool = { x, y ->
  def xString = ToString(a).toString(x)
  def yString = ToString(b).toString(y)
  dbg("xString: " + xString + ", yString: " + yString)
  xString == yString
}

def main = {
  use ToString(int) = ( toString = { i -> "fake" } )
  use ToString(string) = ( toString = { s -> s } )

  compareStrings(42, "fake")
}