{
	"name": "nyx",
	"scopeName": "source.nanyx",
	"patterns": [
		{
			"include": "#comments"
		},
		{
			"include": "#constants"
		},
		{
			"include": "#strings"
		},
		{
			"include": "#chars"
		},
		{
			"include": "#tags"
		},
		{
			"include": "#double_tick"
		},
		{
			"include": "#definition"
		},
		{
			"include": "#abstract_definition"
		},
		{
			"include": "#attributes"
		},
		{
			"include": "#modules"
		},
		{
			"include": "#anonymous_functions"
		},
		{
			"include": "#records"
		},
		{
			"include": "#keywords"
		},
		{
			"include": "#workflows"
		},
		{
			"include": "#text"
		}
	],
	"repository": {
		"record_signature": {
			"patterns": [
				{
					"match": "[[:alpha:]0-9'`^_ ]+(=)([[:alpha:]0-9'`^_ ]+)",
					"captures": {
						"1": {
							"name": "keyword.symbol.nanyx"
						},
						"2": {
							"name": "variable.parameter.nanyx"
						}
					}
				},
				{
					"begin": "({)",
					"end": "(})",
					"beginCaptures": {
						"1": {
							"name": "keyword.symbol.nanyx"
						}
					},
					"endCaptures": {
						"1": {
							"name": "keyword.symbol.nanyx"
						}
					},
					"patterns": [
						{
							"match": "[[:alpha:]0-9'`^_ ]+(=)([[:alpha:]0-9'`^_ ]+)",
							"captures": {
								"1": {
									"name": "keyword.symbol.nanyx"
								},
								"2": {
									"name": "variable.parameter.nanyx"
								}
							}
						},
						{
							"include": "#record_signature"
						}
					]
				},
				{
					"include": "#keywords"
				}
			]
		},
		"record_signature": {
			"patterns": [
				{
					"match": "(([?[:alpha:]0-9'`^._ ]+))+",
					"captures": {
						"1": {
							"name": "entity.name.type.nanyx"
						}
					}
				},
				{
					"begin": "(\\()",
					"end": "(\\))",
					"beginCaptures": {
						"1": {
							"name": "keyword.symbol.nanyx"
						}
					},
					"endCaptures": {
						"1": {
							"name": "keyword.symbol.nanyx"
						}
					},
					"patterns": [
						{
							"match": "(([?[:alpha:]0-9'`^._ ]+))+",
							"captures": {
								"1": {
									"name": "entity.name.type.nanyx"
								}
							}
						},
						{
							"include": "#record_signature"
						}
					]
				},
				{
					"include": "#keywords"
				}
			]
		},
		"anonymous_functions": {
			"patterns": [
				{
					"name": "function.anonymous",
					"begin": "\\b(fun)\\b",
					"end": "(->)",
					"beginCaptures": {
						"1": {
							"name": "keyword.nanyx"
						}
					},
					"endCaptures": {
						"1": {
							"name": "keyword.symbol.arrow.nanyx"
						}
					},
					"patterns": [
						{
							"include": "#comments"
						},
						{
							"begin": "(\\()",
							"end": "\\s*(?=(->))",
							"beginCaptures": {
								"1": {
									"name": "keyword.symbol.nanyx"
								}
							},
							"endCaptures": {
								"1": {
									"name": "keyword.symbol.arrow.nanyx"
								}
							},
							"patterns": [
								{
									"include": "#member_declaration"
								}
							]
						},
						{
							"include": "#variables"
						}
					]
				}
			]
		},
		"comments": {
			"patterns": [
				{
					"name": "comment.block.nanyx",
					"begin": "^(---)",
          "end": "^(---)",
					"beginCaptures": {
						"1": {
							"name": "comment.block.nanyx"
						}
					},
					"endCaptures": {
						"1": {
							"name": "comment.block.nanyx"
						}
					},
					"patterns": [
            {
              "include": "#comments"
            },
						{
							"include": "text.html.markdown"
						}
					]
				},
				{
					"name": "comment.line.double-slash.nanyx",
					"match": "--[^\\-].+"
				}
			]
		},
		"constants": {
			"patterns": [
				{
					"name": "keyword.symbol.nanyx",
					"match": "\\(\\)"
				},
				{
					"name": "constant.numeric.float.nanyx",
					"match": "\\b-?[0-9][0-9_]*((\\.([0-9][0-9_]*([eE][+-]??[0-9][0-9_]*)?)?)|([eE][+-]??[0-9][0-9_]*))"
				},
				{
					"name": "constant.numeric.integer.nativeint.nanyx",
					"match": "\\b(-?((0(x|X)[0-9a-fA-F][0-9a-fA-F_]*)|(0(o|O)[0-7][0-7_]*)|(0(b|B)[01][01_]*)|([0-9][0-9_]*)))"
				},
				{
					"name": "constant.language.boolean.nanyx",
					"match": "\\b(true|false)\\b"
				},
				{
					"name": "constant.other.nanyx",
					"match": "\\b(null|void)\\b"
				}
			]
		},
		"common_binding_definition": {
			"patterns": [
				{
					"include": "#comments"
				},
				{
					"include": "#attributes"
				},
				{
					"include": "#tags"
				},
				{
					"begin": "(:)\\s*(\\()",
					"beginCaptures": {
						"1": {
							"name": "keyword.symbol.nanyx"
						},
						"2": {
							"name": "keyword.symbol.nanyx"
						}
					},
					"end": "(\\)\\s*(([?[:alpha:]0-9'`^._ ]*)))",
					"endCaptures": {
						"1": {
							"name": "keyword.symbol.nanyx"
						},
						"2": {
							"name": "entity.name.type.nanyx"
						}
					},
					"patterns": [
						{
							"include": "#record_signature"
						}
					]
				},
				{
					"begin": "(:)\\s*(\\^[[:alpha:]0-9'._]+)\\s*(when)",
					"beginCaptures": {
						"1": {
							"name": "keyword.symbol.nanyx"
						},
						"2": {
							"name": "entity.name.type.nanyx"
						},
						"3": {
							"name": "keyword.nanyx"
						}
					},
					"end": "(?=:)",
					"endCaptures": {
						"1": {
							"name": "keyword.symbol.nanyx"
						}
					},
					"patterns": [
						{
							"name": "keyword.nanyx",
							"match": "\\b(and|when|or)\\b"
						},
						{
							"comment": "Because we first capture the keywords, we can capture what looks like a word and assume it's an entity definition",
							"match": "([[:alpha:]0-9'^._]+)",
							"captures": {
								"1": {
									"name": "entity.name.type.nanyx"
								}
							}
						},
						{
							"name": "keyword.symbol.nanyx",
							"match": "(\\(|\\))"
						}
					]
				},
				{
					"match": "(:)\\s*([?[:alpha:]0-9'`^._ ]+)",
					"captures": {
						"1": {
							"name": "keyword.symbol.nanyx"
						},
						"2": {
							"name": "entity.name.type.nanyx"
						}
					}
				},
				{
					"match": "(->)\\s*(\\()?\\s*([?[:alpha:]0-9'`^._ ]+)*",
					"captures": {
						"1": {
							"name": "keyword.symbol.arrow.nanyx"
						},
						"2": {
							"name": "keyword.symbol.nanyx"
						},
						"3": {
							"name": "entity.name.type.nanyx"
						}
					}
				},
				{
					"begin": "(\\*)\\s*(\\()",
					"beginCaptures": {
						"1": {
							"name": "keyword.symbol.nanyx"
						},
						"2": {
							"name": "keyword.symbol.nanyx"
						}
					},
					"end": "(\\)\\s*(([?[:alpha:]0-9'`^._ ]+))+)",
					"endCaptures": {
						"1": {
							"name": "keyword.symbol.nanyx"
						},
						"2": {
							"name": "entity.name.type.nanyx"
						}
					},
					"patterns": [
						{
							"include": "#record_signature"
						}
					]
				},
				{
					"begin": "(\\*)(\\s*([?[:alpha:]0-9'`^._ ]+))*",
					"beginCaptures": {
						"1": {
							"name": "keyword.symbol.nanyx"
						},
						"2": {
							"name": "entity.name.type.nanyx"
						}
					},
					"end": "(?==)|(?=\\))",
					"endCaptures": {
						"1": {
							"name": "keyword.symbol.nanyx"
						}
					},
					"patterns": [
						{
							"include": "#record_signature"
						}
					]
				},
				{
					"begin": "(<+(?![[:space:]]*\\)))",
					"beginComment": "The group (?![[:space:]]*\\) is for protection against overload operator. static member (<)",
					"end": "((?<!:)>|\\))",
					"endComment": "The group (?<!:) prevent us from stopping on :> when using SRTP synthax",
					"beginCaptures": {
						"1": {
							"name": "keyword.symbol.nanyx"
						}
					},
					"endCaptures": {
						"1": {
							"name": "keyword.symbol.nanyx"
						}
					},
					"patterns": [
						{
							"include": "#generic_declaration"
						}
					]
				},
				{
					"include": "#anonymous_record_declaration"
				},
				{
					"begin": "({)",
					"end": "(})",
					"beginCaptures": {
						"1": {
							"name": "keyword.symbol.nanyx"
						}
					},
					"endCaptures": {
						"1": {
							"name": "keyword.symbol.nanyx"
						}
					},
					"patterns": [
						{
							"include": "#record_signature"
						}
					]
				},
				{
					"include": "#definition"
				},
				{
					"include": "#variables"
				},
				{
					"include": "#keywords"
				}
			]
		},
    "spec": {
      "patterns": [
        {
          "name": "spec.nanyx",
          "begin": "\\b(spec)\\s+\\(\\)"
        }
      ]
    },
		"definition": {
			"patterns": [
				{
					"name": "binding.nanyx",
					"begin": "(export)?\\b(mut|def|and|default|rec)\\s+([_[:alpha:]]([_[:alpha:]0-9\\._]+)*|``[_[:alpha:]]([_[:alpha:]0-9\\._`\\s]+|(?<=,)\\s)*)?",
					"end": "\\s*(=|->)",
					"beginCaptures": {
						"1": {
							"name": "keyword.nanyx"
						},
						"2": {
							"name": "keyword.nanyx"
						},
						"3": {
							"name": "variable.nanyx"
						}
					},
					"endCaptures": {
						"2": {
							"name": "keyword.nanyx"
						},
						"3": {
							"name": "keyword.symbol.nanyx"
						}
					},
					"patterns": [
						{
							"include": "#common_binding_definition"
						}
					]
				},
				{
					"name": "binding.nanyx",
					"begin": "\\b(use|use!|and|and!)\\s+(\\[[^-=]*\\]|[_[:alpha:]]([_[:alpha:]0-9\\._]+)*|``[_[:alpha:]]([_[:alpha:]0-9\\._`\\s]+|(?<=,)\\s)*)?",
					"end": "\\s*(=)",
					"beginCaptures": {
						"1": {
							"name": "keyword.nanyx"
						}
					},
					"endCaptures": {
						"1": {
							"name": "keyword.symbol.nanyx"
						}
					},
					"patterns": [
						{
							"include": "#common_binding_definition"
						}
					]
				},
				{
					"name": "binding.nanyx",
					"begin": "(?<=with|and)\\s*\\b((get|set)\\s*(?=\\())(\\[[^-=]*\\]|[_[:alpha:]]([_[:alpha:]0-9\\._]+)*|``[_[:alpha:]]([_[:alpha:]0-9\\._`\\s]+|(?<=,)\\s)*)?",
					"end": "\\s*(=|\\n+=|(?<=\\=))",
					"beginCaptures": {
						"4": {
							"name": "variable.nanyx"
						}
					},
					"endCaptures": {
						"1": {
							"name": "keyword.symbol.nanyx"
						}
					},
					"patterns": [
						{
							"include": "#common_binding_definition"
						}
					]
				}
			]
		},
		"keywords": {
			"patterns": [
				{
					"name": "keyword.declaration.nanyx",
					"match": "\\b(def|default|type|trait|mut|where|rec|as|try|export|import|module|or|and|is|pattern|not)(?!')\\b"
				},
				{
					"name": "keyword.control.nanyx",
					"match": "\\b(in|match|except|yield|with|if|then|else|for|in|return|try|finally|while|do|await|try|bind)(?!')\\b"
				},
				{
					"name": "keyword.symbol.arrow.nanyx",
					"match": "(\\->|\\<\\-)"
				},
				{
					"name": "keyword.symbol.nanyx",
					"match": "(&&&|\\|\\|\\||\\^\\^\\^|~~~|~\\+|~\\-|<<<|>>>|\\|>|:>|:\\?>|:|\\[|\\]|\\;|<>|=|@|\\$|\\|\\||&&|&|%|{|}|\\||_|\\.\\.|\\,|\\+|\\-|\\*|\\/|\\^|\\!|\\>|\\>\\=|\\>\\>|\\<|\\<\\=|\\(|\\)|\\<\\<)"
				}
			]
		},
		"modules": {
			"patterns": [
				{
					"name": "entity.name.section.nanyx",
					"begin": "\\b(module)\\s+([[:alpha:]|``][[:alpha:]0-9'_. ]*)",
					"end": "(\\s?=|\\s|$)",
					"beginCaptures": {
						"1": {
							"name": "keyword.nanyx"
						},
						"2": {
							"name": "entity.name.section.nanyx"
						}
					},
					"endCaptures": {
						"1": {
							"name": "keyword.symbol.nanyx"
						}
					},
					"patterns": [
						{
							"name": "entity.name.section.nanyx",
							"match": "(\\.)([A-Z][[:alpha:]0-9'_]*)",
							"captures": {
								"1": {
									"name": "punctuation.separator.namespace-reference.nanyx"
								},
								"2": {
									"name": "entity.name.section.nanyx"
								}
							}
						}
					]
				},
				{
					"name": "import.nanyx",
					"begin": "\\b(import)\\s+([[:alpha:]|``][[:alpha:]0-9'_]*)(?=(\\.[A-Z][[:alpha:]0-9_]*)*)",
					"end": "(\\s|$)",
					"beginCaptures": {
						"1": {
							"name": "keyword.nanyx"
						},
						"2": {
							"name": "entity.name.section.nanyx"
						}
					},
					"patterns": [
						{
							"name": "entity.name.section.nanyx",
							"match": "(\\.)([[:alpha:]][[:alpha:]0-9'_]*)",
							"captures": {
								"1": {
									"name": "punctuation.separator.namespace-reference.nanyx"
								},
								"2": {
									"name": "entity.name.section.nanyx"
								}
							}
						},
						{
							"include": "#comments"
						}
					]
				},
				{
					"name": "namespace.alias.nanyx",
					"begin": "^\\s*(module)\\s+([A-Z][[:alpha:]0-9'_]*)\\s*(=)\\s*([A-Z][[:alpha:]0-9'_]*)",
					"end": "(\\s|$)",
					"beginCaptures": {
						"1": {
							"name": "keyword.nanyx"
						},
						"2": {
							"name": "entity.name.type.namespace.nanyx"
						},
						"3": {
							"name": "keyword.symbol.nanyx"
						},
						"4": {
							"name": "entity.name.section.nanyx"
						}
					},
					"patterns": [
						{
							"name": "entity.name.section.nanyx",
							"match": "(\\.)([A-Z][[:alpha:]0-9'_]*)",
							"captures": {
								"1": {
									"name": "punctuation.separator.namespace-reference.nanyx"
								},
								"2": {
									"name": "entity.name.section.nanyx"
								}
							}
						}
					]
				}
			]
		},
		"strings": {
			"patterns": [
				{
					"name": "string.quoted.literal.nanyx",
					"begin": "(?=[^\\\\])(@\")",
					"end": "(\")(?!\")",
					"beginCaptures": {
						"1": {
							"name": "punctuation.definition.string.begin.nanyx"
						}
					},
					"endCaptures": {
						"1": {
							"name": "punctuation.definition.string.end.nanyx"
						}
					},
					"patterns": [
						{
							"name": "constant.character.string.escape.nanyx",
							"match": "\"(\")"
						}
					]
				},
				{
					"name": "string.quoted.triple.nanyx",
					"begin": "(?=[^\\\\])(\"\"\")",
					"end": "(\"\"\")",
					"beginCaptures": {
						"1": {
							"name": "punctuation.definition.string.begin.nanyx"
						}
					},
					"endCaptures": {
						"1": {
							"name": "punctuation.definition.string.end.nanyx"
						}
					},
					"patterns": [
						{
							"include": "#string_formatter"
						}
					]
				},
				{
					"name": "string.quoted.double.nanyx",
					"begin": "(?=[^\\\\])(\")",
					"end": "(\")",
					"beginCaptures": {
						"1": {
							"name": "punctuation.definition.string.begin.nanyx"
						}
					},
					"endCaptures": {
						"1": {
							"name": "punctuation.definition.string.end.nanyx"
						}
					},
					"patterns": [
						{
							"name": "punctuation.separator.string.ignore-eol.nanyx",
							"match": "\\\\$[ \\t]*"
						},
						{
							"name": "constant.character.string.escape.nanyx",
							"match": "\\\\(['\"\\\\abfnrtv]|([01][0-9][0-9]|2[0-4][0-9]|25[0-5])|(x[0-9a-fA-F]{2})|(u[0-9a-fA-F]{4})|(U00(0[0-9a-fA-F]|10)[0-9a-fA-F]{4}))"
						},
						{
							"name": "invalid.illegal.character.string.nanyx",
							"match": "\\\\(([0-9]{1,3})|(x[^\\s]{0,2})|(u[^\\s]{0,4})|(U[^\\s]{0,8})|[^\\s])"
						},
						{
							"include": "#string_formatter"
						}
					]
				}
			]
		},
		"string_formatter": {
			"patterns": [
				{
					"name": "entity.name.type.format.specifier.nanyx",
					"match": "(%0?-?(\\d+)?((a|t)|(\\.\\d+)?(f|F|e|E|g|G|M)|(b|c|s|d|i|x|X|o|u)|(s|b|O)|(\\+?A)))",
					"captures": {
						"1": {
							"name": "keyword.format.specifier.nanyx"
						}
					}
				}
			]
		},
		"variables": {
			"patterns": [
				{
					"name": "keyword.symbol.nanyx",
					"match": "\\(\\)"
				},
				{
					"match": "(\\?{0,1})(``[[:alpha:]0-9'`^:,._ ]+``|(?!private|struct\\b)\\b[\\w[:alpha:]0-9'`<>^._ ]+)",
					"captures": {
						"1": {
							"name": "keyword.symbol.nanyx"
						},
						"2": {
							"name": "variable.parameter.nanyx"
						}
					}
				}
			]
		},
		"common_declaration": {
			"patterns": [
				{
					"begin": "\\s*(->)\\s*([[:alpha:]0-9'`^._ ]+)(<)",
					"end": "(>)",
					"beginCaptures": {
						"1": {
							"name": "keyword.symbol.arrow.nanyx"
						},
						"2": {
							"name": "entity.name.type.nanyx"
						},
						"3": {
							"name": "keyword.symbol.nanyx"
						}
					},
					"endCaptures": {
						"1": {
							"name": "keyword.symbol.nanyx"
						}
					},
					"patterns": [
						{
							"match": "([[:alpha:]0-9'`^._ ]+)",
							"captures": {
								"1": {
									"name": "entity.name.type.nanyx"
								}
							}
						},
						{
							"include": "#keywords"
						}
					]
				},
				{
					"match": "\\s*(->)\\s*(?!with|get|set\\b)\\b([\\w0-9'`^._]+)",
					"captures": {
						"1": {
